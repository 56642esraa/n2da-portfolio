# Environment Variables Template
# Rename this file to .env.local and fill in your actual values
# This file should NEVER be committed to version control (see .gitignore)

# ===== Site Configuration =====
NEXT_PUBLIC_SITE_URL=https://nadamohamed.com
NEXT_PUBLIC_SITE_NAME=Nada Mohamed

# ===== Contact Information =====
NEXT_PUBLIC_EMAIL=nadaiti2021@gmail.com
NEXT_PUBLIC_PHONE=+20 100 0912 100
NEXT_PUBLIC_WHATSAPP=https://wa.me/201000912100

# ===== Social Media =====
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/nada-mohamed-4b11a61b2
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/nada.mohammed

# ===== Analytics =====
# Google Analytics
NEXT_PUBLIC_GA_ID=G_XXXXXXXXXXXX

# ===== Email Service =====
# Option 1: Formspree
NEXT_PUBLIC_FORMSPREE_ID=f_xxxxxxxxxxxx

# Option 2: SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SENDGRID_FROM_EMAIL=nadaiti2021@gmail.com

# Option 3: Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== CMS Integration (Optional) =====
# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxxxxxx
NEXT_PUBLIC_SANITY_DATASET=production

# Contentful
NEXT_PUBLIC_CONTENTFUL_SPACE_ID=xxxxxxxxxxxx
CONTENTFUL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== API Keys (Optional) =====
# Google Maps (for location features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Database (If needed) =====
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname

# ===== Features Flags =====
NEXT_PUBLIC_ENABLE_BLOG=false
NEXT_PUBLIC_ENABLE_BOOKING=false
NEXT_PUBLIC_ENABLE_NEWSLETTER=true

# ===== Development Settings =====
NODE_ENV=development
NEXT_PUBLIC_DEBUG=false

# ===== CDN Configuration (Optional) =====
NEXT_PUBLIC_CDN_URL=https://cdn.example.com

# Notes:
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Variables without the prefix are only available on the server
# - Never commit .env.local to version control
# - Use .env.example for sharing non-sensitive keys with team
